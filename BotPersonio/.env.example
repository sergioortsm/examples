# Credenciales opcionales para intentar autocompletar login de Microsoft.
# Si MFA es obligatorio, igualmente se requiere confirmacion manual.
# Copia este archivo a .env y rellena tus valores reales.
PERSONIO_SSO_USERNAME=tu.usuario@empresa.com
PERSONIO_SSO_PASSWORD=tu_password

